// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Faculty Model
model Faculty {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  email         String          @unique
  password      String
  firstName     String
  lastName      String
  department    String?
  specialization String?
  phone         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  assignedPapers   AnswerSheet[]
  teacherAnswerKeys TeacherAnswerKey[]

  @@map("faculties")
}

// Student Model
model Student {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  rollNumber    String          @unique
  firstName     String
  lastName      String
  email         String          @unique
  phone         String?
  department    String?
  section       String?
  year          String?
  semester      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  answerSheets  AnswerSheet[]

  @@map("students")
}

// Course Model
model Course {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  code          String          @unique
  name          String
  credits       Int
  description   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  subjects      Subject[]

  @@map("courses")
}

// Subject Model
model Subject {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  code          String          @unique
  name          String
  courseId      String          @db.ObjectId
  maxMarks      Int             @default(50)
  targetMarks   Int             @default(30)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  course        Course          @relation(fields: [courseId], references: [id])
  exams         Exam[]
  questions     Question[]

  @@map("subjects")
}

// Exam Model
model Exam {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  code          String          @unique
  name          String
  subjectId     String          @db.ObjectId
  date          DateTime
  duration      Int
  totalMarks    Int             @default(50)
  answerKeyUrl  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  subject       Subject         @relation(fields: [subjectId], references: [id])
  questions     Question[]
  answerSheets  AnswerSheet[]

  @@map("exams")
}

// Question Model
model Question {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  examId        String          @db.ObjectId
  subjectId     String          @db.ObjectId
  questionNumber Int
  maxMarks      Int
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  exam          Exam            @relation(fields: [examId], references: [id])
  subject       Subject         @relation(fields: [subjectId], references: [id])
  marks         Mark[]

  @@map("questions")
}

// Answer Sheet Model
model AnswerSheet {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  examId        String          @db.ObjectId
  studentId     String          @db.ObjectId
  facultyId     String          @db.ObjectId
  studentAnswerSheetUrl String
  answerKeyUrl  String
  status        String          @default("ASSIGNED")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  exam          Exam            @relation(fields: [examId], references: [id])
  student       Student         @relation(fields: [studentId], references: [id])
  faculty       Faculty         @relation(fields: [facultyId], references: [id])
  evaluation    Evaluation?

  @@map("answer_sheets")
}

// Evaluation Model
model Evaluation {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  answerSheetId String          @unique @db.ObjectId
  status        String          @default("DRAFT")
  totalObtainedMarks Float       @default(0)
  totalConvertedMarks Float      @default(0)
  targetMarks   Int             @default(0)
  remarks       String?
  customMarks   Json?           // [{label, obtainedMarks, maxMarks}]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  answerSheet   AnswerSheet     @relation(fields: [answerSheetId], references: [id])
  marks         Mark[]

  @@map("evaluations")
}

// Teacher Answer Key Model (teacher-uploaded, independent of Exam)
model TeacherAnswerKey {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  facultyId    String   @db.ObjectId
  title        String
  department   String?
  subject      String?
  examName     String?
  year         String?
  semester     String?
  notes        String?
  fileUrl      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  faculty      Faculty  @relation(fields: [facultyId], references: [id])

  @@map("teacher_answer_keys")
}

// Mark Model
model Mark {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  evaluationId  String          @db.ObjectId
  questionId    String          @db.ObjectId
  obtainedMarks Float           @default(0)
  convertedMarks Float          @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  evaluation    Evaluation      @relation(fields: [evaluationId], references: [id])
  question      Question        @relation(fields: [questionId], references: [id])

  @@unique([evaluationId, questionId])
  @@map("marks")
}
